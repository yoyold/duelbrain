{
  "expo": {
    "name": "DuelBrain",
    "slug": "duelbrain",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "duelbrain",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.duelbrain.app"
    },
    "android": {
      "package": "com.duelbrain.app",
      "adaptiveIcon": {
        "backgroundColor": "#0f0a1a",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0f0a1a",
          "dark": {
            "backgroundColor": "#0f0a1a"
          }
        }
      ],
      "expo-sqlite",
      [
        "expo-image-picker",
        {
          "cameraPermission": "DuelBrain uses the camera to scan Yu-Gi-Oh! cards and match them against the catalog.",
          "photosPermission": "DuelBrain reads photos so you can pick a card image from your library instead of re-shooting."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
